<view class="products-page">
  <!-- 搜索框 -->
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索商品名称"
      value="{{keyword}}"
      bindinput="onKeywordInput"
      bindconfirm="onSearch"
    />
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>

  <!-- 商品列表 -->
  <view wx:if="{{productList.length === 0 && !loading}}" class="empty">
    <text>暂无商品</text>
  </view>

  <view class="product-list">
    <view wx:for="{{productList}}" wx:key="id" class="product-card">
      <image class="product-img" src="{{item.image}}" mode="aspectFill" />
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <text class="product-sub">{{item.subtitle}}</text>
        <view class="product-meta">
          <text class="price">¥{{item.price}}</text>
          <text class="stock">库存 {{item.stock}}</text>
        </view>
      </view>
      <view class="product-action">
        <view
          class="toggle-btn {{item.status === 1 ? 'btn-off' : 'btn-on'}}"
          bindtap="onToggleStatus"
          data-id="{{item.id}}"
          data-status="{{item.status}}"
        >{{item.status === 1 ? '下架' : '上架'}}</view>
        <text class="status-tag {{item.status === 1 ? 'tag-on' : 'tag-off'}}">
          {{item.status === 1 ? '已上架' : '已下架'}}
        </text>
      </view>
    </view>
  </view>

  <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">加载更多</view>
  <view wx:if="{{!hasMore && productList.length > 0}}" class="no-more">没有更多了</view>
</view>
