.products-page {
  background: #f5f5f5;
  min-height: 100vh;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx 24rpx;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #333;
}

.search-btn {
  background: #1890ff;
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  white-space: nowrap;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #aaa;
  font-size: 28rpx;
}

.product-list { padding: 20rpx; }

.product-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.product-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.product-info {
  flex: 1;
  padding: 0 20rpx;
  overflow: hidden;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-sub {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin: 6rpx 0;
}

.product-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.price { font-size: 28rpx; color: #f5222d; font-weight: 600; }
.stock { font-size: 24rpx; color: #aaa; }

.product-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.toggle-btn {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
}
.btn-off { background: #fff3f3; color: #f5222d; border: 1rpx solid #ffd4d4; }
.btn-on { background: #f0fff4; color: #52c41a; border: 1rpx solid #b7f5c5; }

.status-tag { font-size: 22rpx; }
.tag-on { color: #52c41a; }
.tag-off { color: #aaa; }

.load-more, .no-more {
  text-align: center;
  padding: 24rpx;
  font-size: 26rpx;
  color: #aaa;
}
