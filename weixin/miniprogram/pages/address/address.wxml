<view class="address-page">
  <view class="address-form" wx:if="{{action === 'add' || action === 'edit'}}">
    <view class="form-item">
      <text class="label">收货人</text>
      <input class="input" placeholder="请输入收货人姓名" value="{{formData.consignee}}" bindinput="onConsigneeInput" />
    </view>
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{formData.phone}}" bindinput="onPhoneInput" />
    </view>
    <view class="form-item">
      <text class="label">省份</text>
      <input class="input" placeholder="请输入省份" value="{{formData.province}}" bindinput="onProvinceInput" />
    </view>
    <view class="form-item">
      <text class="label">城市</text>
      <input class="input" placeholder="请输入城市" value="{{formData.city}}" bindinput="onCityInput" />
    </view>
    <view class="form-item">
      <text class="label">区县</text>
      <input class="input" placeholder="请输入区县" value="{{formData.district}}" bindinput="onDistrictInput" />
    </view>
    <view class="form-item">
      <text class="label">详细地址</text>
      <input class="input" placeholder="请输入详细地址" value="{{formData.detail}}" bindinput="onDetailInput" />
    </view>
    <view class="form-item">
      <text class="label">设为默认</text>
      <switch checked="{{formData.isDefault === 1}}" bindchange="onDefaultChange" />
    </view>
    <view class="form-actions">
      <button class="btn cancel" bindtap="onCancelAddress">取消</button>
      <button class="btn confirm" bindtap="onSaveAddress">保存</button>
    </view>
  </view>

  <view class="address-list" wx:elif="{{addresses.length > 0}}">
    <view
      class="address-item"
      wx:for="{{addresses}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onSelectAddress"
    >
      <view class="address-info">
        <view class="info-top">
          <text class="consignee">{{item.consignee}}</text>
          <text class="phone">{{item.phone}}</text>
          <view class="default-tag" wx:if="{{item.isDefault === 1}}">默认</view>
        </view>
        <text class="detail">{{item.fullAddress}}</text>
      </view>
      <view class="address-actions">
        <text class="action-btn edit" data-id="{{item.id}}" catchtap="onEditAddress">编辑</text>
        <text class="action-btn delete" data-id="{{item.id}}" catchtap="onDeleteAddress">删除</text>
      </view>
    </view>
  </view>

  <view class="empty-tip" wx:elif="{{addresses.length === 0 && !action}}">
    <text>暂无收货地址</text>
  </view>

  <view class="bottom-bar" wx:if="{{!action}}">
    <view class="add-btn" bindtap="onAddAddress">添加新地址</view>
  </view>
</view>