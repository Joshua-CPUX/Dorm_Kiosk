/* 地址管理页 */
.address-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* 地址表单 */
.address-form {
  background: #ffffff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-of-type {
  border-bottom: none;
}

.form-item .label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333333;
  flex-shrink: 0;
}

.form-item .input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  text-align: right;
}

.form-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.form-actions .btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.form-actions .btn.cancel {
  background: #f5f5f5;
  color: #666666;
}

.form-actions .btn.confirm {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: #ffffff;
}

/* 地址列表 */
.address-list {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.address-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  transition: transform 0.1s;
}

.address-item:active {
  transform: scale(0.98);
}

.address-info {
  flex: 1;
  min-width: 0;
}

.info-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.consignee {
  font-size: 30rpx;
  font-weight: 600;
  color: #222222;
}

.phone {
  font-size: 26rpx;
  color: #666666;
}

.default-tag {
  background: #e6f7ff;
  color: #1890ff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  border: 1rpx solid #91d5ff;
  font-weight: 500;
}

.detail {
  font-size: 26rpx;
  color: #888888;
  line-height: 1.5;
  display: block;
}

/* 操作按钮 */
.address-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  text-align: center;
}

.action-btn.edit {
  color: #1890ff;
  border: 1rpx solid #91d5ff;
  background: #e6f7ff;
}

.action-btn.delete {
  color: #ff4d4f;
  border: 1rpx solid #ffccc7;
  background: #fff2f0;
}

/* 空状态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
  color: #bbbbbb;
  font-size: 28rpx;
}

/* 底部添加按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.08);
}

.add-btn {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: #ffffff;
  border-radius: 48rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  box-shadow: 0 4rpx 16rpx rgba(24, 144, 255, 0.4);
}
