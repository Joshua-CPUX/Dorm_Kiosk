.address-page {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 180rpx;
}

.address-form {
  background: #ffffff;
  margin: 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-of-type {
  border-bottom: none;
}

.form-item .label {
  width: 160rpx;
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  flex-shrink: 0;
}

.form-item .input {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a1a;
  text-align: right;
}

.form-item .picker {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.form-item .picker .text {
  font-size: 30rpx;
  color: #1a1a1a;
}

.form-item .picker .placeholder {
  font-size: 28rpx;
  color: #999999;
}

.form-item .picker .arrow {
  font-size: 32rpx;
  color: #cccccc;
  margin-left: 12rpx;
}

.form-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.form-actions .btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.form-actions .btn.cancel {
  background: #f5f5f5;
  color: #666666;
}

.form-actions .btn.cancel:active {
  background: #e8e8e8;
}

.form-actions .btn.confirm {
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 53, 0.4);
}

.form-actions .btn.confirm:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 10rpx rgba(255, 107, 53, 0.5);
}

.address-list {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.address-item {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  transition: all 0.2s ease;
}

.address-item:active {
  transform: scale(0.99);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.address-info {
  flex: 1;
  min-width: 0;
}

.info-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.consignee {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.phone {
  font-size: 28rpx;
  color: #666666;
}

.default-tag {
  background: rgba(255, 107, 53, 0.1);
  color: #ff6b35;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 107, 53, 0.2);
}

.detail {
  font-size: 28rpx;
  color: #888888;
  line-height: 1.6;
  display: block;
}

.address-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
}

.action-btn {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 28rpx;
  text-align: center;
  font-weight: 500;
}

.action-btn.edit {
  color: #ff6b35;
  border: 2rpx solid rgba(255, 107, 53, 0.3);
  background: rgba(255, 107, 53, 0.05);
}

.action-btn.edit:active {
  background: rgba(255, 107, 53, 0.1);
}

.action-btn.delete {
  color: #ff4d4f;
  border: 2rpx solid rgba(255, 77, 79, 0.3);
  background: rgba(255, 77, 79, 0.05);
}

.action-btn.delete:active {
  background: rgba(255, 77, 79, 0.1);
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
  color: #999999;
  font-size: 30rpx;
}

.empty-icon {
  font-size: 160rpx;
  margin-bottom: 40rpx;
  opacity: 0.4;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.add-btn {
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  color: #ffffff;
  border-radius: 56rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4);
}

.add-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.5);
}