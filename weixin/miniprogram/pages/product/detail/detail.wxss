/* 商品详情页 */
.product-detail {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* 商品图片 */
.detail-image {
  width: 100%;
  height: 560rpx;
  overflow: hidden;
  background: #f0f0f0;
}

.detail-image image {
  width: 100%;
  height: 560rpx;
  display: block;
}

/* 商品信息卡片 */
.detail-info {
  background: #ffffff;
  padding: 32rpx 24rpx 24rpx;
  margin-bottom: 16rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.price {
  font-size: 48rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.original-price {
  font-size: 28rpx;
  color: #bbbbbb;
  text-decoration: line-through;
}

.name {
  font-size: 36rpx;
  font-weight: 600;
  color: #222222;
  display: block;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #888888;
  display: block;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.stock-row {
  display: flex;
  gap: 32rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.stock,
.sales {
  font-size: 24rpx;
  color: #aaaaaa;
}

/* 商品详情文字 */
.detail-content {
  background: #ffffff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.content-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.description {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.08);
  gap: 16rpx;
}

.action-icons {
  display: flex;
  gap: 8rpx;
}

.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 16rpx;
  min-width: 80rpx;
}

.icon-item .icon {
  font-size: 40rpx;
}

.icon-item .label {
  font-size: 20rpx;
  color: #888888;
  margin-top: 4rpx;
}

.action-buttons {
  flex: 1;
  display: flex;
  gap: 16rpx;
}

.btn-add {
  flex: 1;
  background: #fff7e6;
  color: #fa8c16;
  border-radius: 48rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid #ffd591;
}

.btn-buy {
  flex: 1;
  background: linear-gradient(135deg, #ff4d4f, #cf1322);
  color: #ffffff;
  border-radius: 48rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}
