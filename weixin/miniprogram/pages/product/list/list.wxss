/* 商品列表页 */
.product-list {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 搜索栏 */
.search-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #ffffff;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.search-wrapper {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  padding: 0 16rpx;
}

.clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.clear-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 商品网格 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx;
  gap: 16rpx;
}

.product-item {
  width: calc(50% - 8rpx);
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
}

.product-item:active {
  transform: scale(0.98);
}

.image-wrapper {
  position: relative;
  width: 100%;
  height: 320rpx;
}

.product-image {
  width: 100%;
  height: 100%;
  display: block;
  background: #f0f0f0;
}

.product-image-placeholder {
  width: 100%;
  height: 100%;
  display: block;
  background: #f0f0f0;
}

.add-btn-small {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff4757);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 71, 87, 0.4);
  transition: transform 0.2s;
}

.add-btn-small:active {
  transform: scale(0.9);
}

.add-text {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
  line-height: 1;
}

.out-of-stock {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.6);
  color: #ffffff;
  font-size: 24rpx;
  padding: 12rpx 32rpx;
  border-radius: 8rpx;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.product-subtitle {
  font-size: 22rpx;
  color: #999999;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 12rpx;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-section {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.product-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.product-sales {
  font-size: 22rpx;
  color: #bbbbbb;
}

/* 加载提示 */
.loading-tip {
  text-align: center;
  padding: 32rpx;
  color: #bbbbbb;
  font-size: 26rpx;
}

/* 空状态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: #bbbbbb;
  font-size: 28rpx;
}
