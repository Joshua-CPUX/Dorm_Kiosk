/* 商品列表页 */
.product-list {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 搜索栏 */
.search-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #ffffff;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.search-bar input {
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #333333;
  width: 100%;
}

/* 商品网格 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx;
  gap: 16rpx;
}

.product-item {
  width: calc(50% - 8rpx);
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.1s;
}

.product-item:active {
  transform: scale(0.97);
}

.product-image {
  width: 100%;
  height: 280rpx;
  display: block;
  background: #f0f0f0;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-subtitle {
  font-size: 22rpx;
  color: #999999;
  display: block;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.product-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.product-sales {
  font-size: 22rpx;
  color: #bbbbbb;
}

/* 加载提示 */
.loading-tip {
  text-align: center;
  padding: 32rpx;
  color: #bbbbbb;
  font-size: 26rpx;
}

/* 空状态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: #bbbbbb;
  font-size: 28rpx;
}
