.product-list {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 40rpx;
}

.search-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #ffffff;
  padding: 20rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.search-wrapper {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 48rpx;
  padding: 16rpx 28rpx;
  transition: all 0.2s ease;
}

.search-wrapper:focus-within {
  background: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 53, 0.1);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a1a;
  padding: 0 20rpx;
}

.clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  background: #e8e8e8;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.clear-btn:active {
  background: #cccccc;
  transform: scale(0.9);
}

.clear-icon {
  width: 28rpx;
  height: 28rpx;
}

.category-tabs {
  display: flex;
  padding: 20rpx 24rpx;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
  background: #ffffff;
}

.category-tabs::-webkit-scrollbar {
  display: none;
}

.tab-item {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-item.active {
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.4);
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  gap: 20rpx;
}

.product-item {
  width: calc(50% - 10rpx);
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.product-item:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.image-wrapper {
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 100%;
  display: block;
  background: #f5f5f5;
  transition: transform 0.3s ease;
}

.product-item:active .product-image {
  transform: scale(1.05);
}

.product-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f0f0f0 0%, #e8e8e8 100%);
}

.product-image-placeholder text {
  font-size: 24rpx;
  color: #cccccc;
}

.add-btn-small {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 53, 0.4);
  transition: all 0.2s ease;
}

.add-btn-small:active {
  transform: scale(0.85);
}

.add-text {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: bold;
  line-height: 1;
}

.out-of-stock {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.65);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 500;
  padding: 16rpx 40rpx;
  border-radius: 12rpx;
  backdrop-filter: blur(10rpx);
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.product-subtitle {
  font-size: 24rpx;
  color: #999999;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-section {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.product-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff6b35;
}

.product-original-price {
  font-size: 22rpx;
  color: #cccccc;
  text-decoration: line-through;
}

.product-sales {
  font-size: 22rpx;
  color: #bbbbbb;
}

.loading-tip {
  text-align: center;
  padding: 40rpx;
  color: #bbbbbb;
  font-size: 28rpx;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
  color: #999999;
  font-size: 30rpx;
}

.empty-icon {
  font-size: 160rpx;
  margin-bottom: 40rpx;
  opacity: 0.4;
}