.list-container {
  display: flex;
  height: 100vh;
}

.category-sidebar {
  width: 180rpx;
  background: #f8f9fa;
  flex-shrink: 0;
  border-right: 1px solid #eeeeee;
}

.sidebar-inner {
  padding-top: 20rpx;
}

.category-item {
  padding: 28rpx 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666666;
  border-left: 6rpx solid transparent;
  transition: all 0.2s ease;
  position: relative;
}

.category-item:active {
  background: rgba(255, 107, 53, 0.05);
}

.category-item.active {
  background: #ffffff;
  color: #ff6b35;
  border-left-color: #ff6b35;
  font-weight: 600;
}

.category-item.active::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 40rpx;
  background: #ff6b35;
  border-radius: 2rpx;
}

.product-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: #ffffff;
}

.search-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #ffffff;
  padding: 20rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.search-wrapper {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 48rpx;
  padding: 16rpx 28rpx;
  transition: all 0.2s ease;
}

.search-wrapper:focus-within {
  background: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 53, 0.1);
}

.search-icon-text {
  font-size: 32rpx;
  flex-shrink: 0;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a1a;
  padding: 0 20rpx;
}

.clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  background: #e8e8e8;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.clear-btn:active {
  background: #cccccc;
  transform: scale(0.9);
}

.clear-icon-text {
  font-size: 24rpx;
  color: #999;
}

.product-scroll {
  flex: 1;
  height: calc(100vh - 140rpx);
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  gap: 20rpx;
}

.product-item {
  width: calc(50% - 10rpx);
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.product-item:active {
  transform: scale(0.96);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.08);
}

.image-wrapper {
  position: relative;
  width: 100%;
  height: 280rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 100%;
  display: block;
  background: #f5f5f5;
  transition: transform 0.3s ease;
}

.product-item:active .product-image {
  transform: scale(1.05);
}

.product-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f0f0f0 0%, #e8e8e8 100%);
}

.product-image-placeholder text {
  font-size: 24rpx;
  color: #cccccc;
}

.add-btn-small {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.4);
  transition: all 0.2s ease;
}

.add-btn-small:active {
  transform: scale(0.85);
}

.add-text {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
  line-height: 1;
}

.out-of-stock {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.65);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
  padding: 12rpx 32rpx;
  border-radius: 8rpx;
  backdrop-filter: blur(10rpx);
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.product-subtitle {
  font-size: 22rpx;
  color: #999999;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 12rpx;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-section {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.product-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff6b35;
}

.product-original-price {
  font-size: 20rpx;
  color: #cccccc;
  text-decoration: line-through;
}

.product-sales {
  font-size: 20rpx;
  color: #bbbbbb;
}

.loading-tip {
  text-align: center;
  padding: 40rpx;
  color: #bbbbbb;
  font-size: 26rpx;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
  color: #999999;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
}