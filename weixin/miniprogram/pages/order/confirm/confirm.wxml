<view class="confirm-page">
  <view class="address-section" bindtap="onSelectAddress">
    <view class="address-content" wx:if="{{address}}">
      <view class="address-info">
        <text class="consignee">{{address.consignee}}</text>
        <text class="phone">{{address.phone}}</text>
      </view>
      <text class="address-detail">{{address.fullAddress}}</text>
    </view>
    <view class="no-address" wx:else>
      <text>请添加收货地址</text>
    </view>
    <text class="arrow">></text>
  </view>

  <view class="order-type">
    <view class="type-item {{orderType === 1 ? 'active' : ''}}" data-type="1" bindtap="onOrderTypeChange">
      <text class="type-icon">🏃</text>
      <text class="type-name">自取</text>
    </view>
    <view class="type-item {{orderType === 2 ? 'active' : ''}}" data-type="2" bindtap="onOrderTypeChange">
      <text class="type-icon">🚚</text>
      <text class="type-name">配送</text>
    </view>
  </view>

  <view class="remark-section">
    <text class="remark-label">备注:</text>
    <input
      type="text"
      placeholder="请输入备注信息"
      value="{{remark}}"
      bindinput="onRemarkInput"
    />
  </view>

  <view class="bottom-bar">
    <view class="total-info">
      <text class="total-label">合计:</text>
      <text class="total-price">¥{{totalAmount}}</text>
    </view>
    <view class="submit-btn" bindtap="onSubmit">提交订单</view>
  </view>
</view>
