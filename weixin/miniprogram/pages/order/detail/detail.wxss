/* 订单详情页 */
.order-detail-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* 状态区域 */
.status-section {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  padding: 60rpx 24rpx 80rpx;
  text-align: center;
}

.status-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
}

/* 地址区域 */
.address-section {
  background: #ffffff;
  padding: 32rpx 24rpx;
  margin: -40rpx 24rpx 16rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  position: relative;
}

.address-section::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: repeating-linear-gradient(
    90deg,
    #1890ff 0%,
    #1890ff 50%,
    transparent 50%,
    transparent 100%
  );
  background-size: 20rpx 6rpx;
}

.consignee {
  font-size: 30rpx;
  font-weight: 600;
  color: #222222;
  display: block;
  margin-bottom: 12rpx;
}

.address {
  font-size: 26rpx;
  color: #888888;
  line-height: 1.5;
  display: block;
}

/* 订单信息卡 */
.order-info {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 0 24rpx 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row .label {
  font-size: 26rpx;
  color: #888888;
  flex-shrink: 0;
}

.info-row .value {
  font-size: 26rpx;
  color: #333333;
  text-align: right;
}

/* 商品列表 */
.product-section {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 0 24rpx 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.product-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.product-item:last-child {
  border-bottom: none;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.product-info {
  flex: 1;
  min-width: 0;
}

.product-name {
  font-size: 28rpx;
  color: #333333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.product-bottom {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.product-price {
  font-size: 26rpx;
  color: #ff4d4f;
}

.product-quantity {
  font-size: 24rpx;
  color: #999999;
}

.product-total {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  flex-shrink: 0;
}

/* 金额区域 */
.amount-section {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 0 24rpx 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.amount-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.amount-row:last-child {
  border-bottom: none;
}

.amount-row.total {
  background: #fafafa;
}

.amount-row .label {
  font-size: 26rpx;
  color: #888888;
}

.amount-row .value {
  font-size: 28rpx;
  color: #333333;
}

.amount-row.total .value {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4d4f;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0 24rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.08);
  gap: 20rpx;
}

.btn {
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn.cancel {
  border: 2rpx solid #d9d9d9;
  color: #666666;
  background: #ffffff;
}

.btn.pay {
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.4);
}

.btn.confirm {
  background: linear-gradient(135deg, #ff4d4f, #cf1322);
  color: #ffffff;
}
