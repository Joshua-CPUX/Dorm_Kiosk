<view class="order-detail-page">
  <view class="status-section">
    <text class="status-text status-{{order.status}}">{{order.statusName}}</text>
  </view>

  <view class="address-section" wx:if="{{order.address}}">
    <text class="consignee">{{order.address.consignee}} {{order.address.phone}}</text>
    <text class="address">{{order.address.fullAddress}}</text>
  </view>

  <view class="order-info">
    <view class="info-row">
      <text class="label">订单号:</text>
      <text class="value">{{order.orderNo}}</text>
    </view>
    <view class="info-row">
      <text class="label">下单时间:</text>
      <text class="value">{{order.createTime}}</text>
    </view>
    <view class="info-row" wx:if="{{order.payTime}}">
      <text class="label">支付时间:</text>
      <text class="value">{{order.payTime}}</text>
    </view>
  </view>

  <view class="product-section">
    <view class="product-item" wx:for="{{order.items}}" wx:key="id">
      <image src="{{item.productImage}}" mode="aspectFill" class="product-image" />
      <view class="product-info">
        <text class="product-name">{{item.productName}}</text>
        <view class="product-bottom">
          <text class="product-price">¥{{item.price}}</text>
          <text class="product-quantity">x{{item.quantity}}</text>
        </view>
      </view>
      <text class="product-total">¥{{item.totalPrice}}</text>
    </view>
  </view>

  <view class="amount-section">
    <view class="amount-row">
      <text class="label">商品总额:</text>
      <text class="value">¥{{order.totalAmount}}</text>
    </view>
    <view class="amount-row">
      <text class="label">运费:</text>
      <text class="value">¥{{order.freight || 0}}</text>
    </view>
    <view class="amount-row total">
      <text class="label">实付金额:</text>
      <text class="value">¥{{order.payAmount}}</text>
    </view>
  </view>

  <view class="bottom-bar" wx:if="{{order.status === 1 || order.status === 4}}">
    <view class="btn cancel" wx:if="{{order.status === 1}}" bindtap="onCancel">取消订单</view>
    <view class="btn pay" wx:if="{{order.status === 1}}" bindtap="onPay">立即支付</view>
    <view class="btn confirm" wx:if="{{order.status === 4}}" bindtap="onConfirm">确认收货</view>
  </view>
</view>
