/* 订单列表页 */
.order-list-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 状态 Tab */
.status-tabs {
  display: flex;
  background: #ffffff;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 8rpx;
  font-size: 26rpx;
  color: #888888;
  position: relative;
  white-space: nowrap;
  transition: color 0.2s;
}

.tab-item.active {
  color: #1890ff;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #1890ff;
  border-radius: 2rpx;
}

/* 订单列表 */
.order-list {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.order-item {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-no {
  font-size: 24rpx;
  color: #999999;
}

.order-status {
  font-size: 26rpx;
  font-weight: 500;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
}

.status-1 { color: #fa8c16; background: #fff7e6; }
.status-2 { color: #1890ff; background: #e6f7ff; }
.status-3 { color: #52c41a; background: #f6ffed; }
.status-4 { color: #722ed1; background: #f9f0ff; }
.status-5 { color: #ff4d4f; background: #fff2f0; }

/* 订单商品 */
.order-products {
  padding: 16rpx 24rpx;
}

.product-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.product-item:last-child {
  border-bottom: none;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.product-info {
  flex: 1;
  min-width: 0;
}

.product-name {
  font-size: 28rpx;
  color: #333333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-top: 8rpx;
}

/* 订单底部 */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fafafa;
  border-top: 1rpx solid #f0f0f0;
}

.order-amount {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.order-amount text {
  color: #ff4d4f;
  font-size: 30rpx;
  font-weight: 700;
}

.order-time {
  font-size: 22rpx;
  color: #bbbbbb;
}

/* 空状态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
  color: #bbbbbb;
  font-size: 28rpx;
}
