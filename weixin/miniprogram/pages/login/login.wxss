/* 登录/注册页 */
.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1890ff 0%, #096dd9 40%, #f5f5f5 40%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx 60rpx;
}

/* 头部 logo 区域 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 60rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 16rpx;
  margin-bottom: 20rpx;
}

.app-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 4rpx;
}

.app-slogan {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 12rpx;
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 48rpx;
  padding: 6rpx;
  margin-bottom: 32rpx;
  width: 340rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.7);
  border-radius: 44rpx;
  transition: all 0.2s;
  font-weight: 500;
}

.tab.active {
  background: #ffffff;
  color: #1890ff;
  font-weight: 600;
}

/* 表单卡片 */
.form-card {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.12);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 26rpx;
  color: #888888;
  display: block;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #333333;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.form-input:focus {
  border-color: #1890ff;
  background: #f0f7ff;
}

/* 提交按钮 */
.submit-btn {
  margin-top: 16rpx;
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: #ffffff;
  border-radius: 48rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 24rpx rgba(24, 144, 255, 0.4);
  transition: opacity 0.2s;
}

.submit-btn:active {
  opacity: 0.85;
}

.submit-btn.disabled {
  opacity: 0.6;
}
