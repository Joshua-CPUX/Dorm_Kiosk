<view class="login-page">
  <view class="header">
    <image class="logo" src="/assets/images/home-active.png" mode="aspectFit" />
    <text class="app-name">校园小卖部</text>
    <text class="app-slogan">快捷购物，轻松生活</text>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view class="tab {{mode === 'login' ? 'active' : ''}}" bindtap="switchMode" data-mode="login">登录</view>
    <view class="tab {{mode === 'register' ? 'active' : ''}}" bindtap="switchMode" data-mode="register">注册</view>
  </view>

  <view class="form-card">
    <!-- 用户名 -->
    <view class="form-item">
      <text class="form-label">用户名</text>
      <input
        class="form-input"
        type="text"
        placeholder="请输入用户名"
        value="{{username}}"
        bindinput="onUsernameInput"
        maxlength="20"
      />
    </view>

    <!-- 昵称（仅注册） -->
    <view class="form-item" wx:if="{{mode === 'register'}}">
      <text class="form-label">昵称</text>
      <input
        class="form-input"
        type="text"
        placeholder="请输入昵称（选填）"
        value="{{nickname}}"
        bindinput="onNicknameInput"
        maxlength="20"
      />
    </view>

    <!-- 手机号（仅注册） -->
    <view class="form-item" wx:if="{{mode === 'register'}}">
      <text class="form-label">手机号</text>
      <input
        class="form-input"
        type="number"
        placeholder="请输入手机号（选填）"
        value="{{phone}}"
        bindinput="onPhoneInput"
        maxlength="11"
      />
    </view>

    <!-- 密码 -->
    <view class="form-item">
      <text class="form-label">密码</text>
      <input
        class="form-input"
        password
        placeholder="{{mode === 'login' ? '请输入密码' : '请输入密码（6-20位）'}}"
        value="{{password}}"
        bindinput="onPasswordInput"
        maxlength="20"
      />
    </view>

    <view class="submit-btn {{loading ? 'disabled' : ''}}" bindtap="onSubmit">
      <text wx:if="{{!loading}}">{{mode === 'login' ? '登 录' : '注 册'}}</text>
      <text wx:else>处理中...</text>
    </view>
  </view>
</view>
