/* 首页 */
.index {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* Banner 轮播 */
.banner {
  width: 100%;
  height: 360rpx;
  overflow: hidden;
}

.banner swiper {
  height: 360rpx;
}

.banner swiper-item image {
  width: 100%;
  height: 360rpx;
  display: block;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
}

/* 通用 section 标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222222;
  padding: 32rpx 24rpx 20rpx;
  position: relative;
}

.section-title::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 32rpx;
  background: #1890ff;
  border-radius: 3rpx;
  margin-right: 16rpx;
  vertical-align: middle;
}

/* 分类区域 */
.category-section {
  background: #ffffff;
  margin: 20rpx 0;
  padding-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 12rpx;
}

.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
}

.category-icon {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #e8f4ff 0%, #d0e8ff 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.category-icon .icon {
  font-size: 44rpx;
}

.category-name {
  font-size: 24rpx;
  color: #555555;
  text-align: center;
  line-height: 1.4;
}

/* 热门商品 */
.product-section {
  background: #f5f5f5;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 16rpx;
  gap: 16rpx;
}

.product-item {
  width: calc(50% - 8rpx);
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.1s;
}

.product-item:active {
  transform: scale(0.97);
}

.product-image {
  width: 100%;
  height: 280rpx;
  display: block;
  background: #f0f0f0;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-subtitle {
  font-size: 22rpx;
  color: #999999;
  display: block;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.product-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.product-sales {
  font-size: 22rpx;
  color: #bbbbbb;
}
