.index {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 40rpx;
}

.banner {
  width: 100%;
  height: 240rpx;
  overflow: hidden;
  position: relative;
}

.banner swiper {
  height: 240rpx;
}

.banner swiper-item {
  position: relative;
}

.banner swiper-item image {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 0 0 32rpx 32rpx;
}

.banner-placeholder {
  width: 100%;
  height: 240rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 0 32rpx 32rpx;
}

.banner-placeholder text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.announcement-bar {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #fff8e6 0%, #fff3cc 100%);
  padding: 20rpx 24rpx;
  margin: 24rpx;
  border-radius: 16rpx;
  gap: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(255, 193, 7, 0.15);
}

.announcement-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.announcement-text {
  flex: 1;
  font-size: 26rpx;
  color: #b8860b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx 24rpx;
  gap: 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  flex: 1;
}

.section-badge {
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 500;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.section-more {
  font-size: 26rpx;
  color: #999999;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.section-more::after {
  content: '›';
  font-size: 32rpx;
  color: #cccccc;
}

.product-section {
  background: #ffffff;
  margin: 0 24rpx;
  border-radius: 24rpx;
  padding-bottom: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 16rpx 16rpx;
  gap: 16rpx;
}

.product-item {
  width: calc(50% - 8rpx);
  background: #f8f9fa;
  border-radius: 16rpx;
  overflow: hidden;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.product-item:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.product-image-wrapper {
  position: relative;
  width: 100%;
  height: 240rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 100%;
  display: block;
  background: #f0f0f0;
}

.product-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f0f0f0 0%, #e8e8e8 100%);
}

.product-image-placeholder text {
  font-size: 24rpx;
  color: #cccccc;
}

.product-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.product-subtitle {
  font-size: 22rpx;
  color: #999999;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 12rpx;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-wrapper {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.product-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff6b35;
}

.product-original-price {
  font-size: 22rpx;
  color: #cccccc;
  text-decoration: line-through;
}

.add-cart-btn {
  width: 52rpx;
  height: 52rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.4);
  transition: all 0.2s ease;
}

.add-cart-btn:active {
  transform: scale(0.9);
}

.add-cart-btn text {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
  line-height: 1;
}