<view class="user-page">
  <view class="user-header" bindtap="onLogoTap">
    <view class="avatar-wrapper">
      <image wx:if="{{userInfo.avatar}}" src="{{userInfo.avatar}}" class="avatar" />
      <view wx:else class="avatar-placeholder">
        <text>👤</text>
      </view>
    </view>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname || '未登录'}}</text>
      <text class="user-id" wx:if="{{userInfo.id}}">ID: {{userInfo.id}}</text>
    </view>
    <view wx:if="{{userInfo.role === 1}}" class="owner-badge">店主</view>
  </view>

  <view class="order-section">
    <view class="order-header">
      <text class="order-title">我的订单</text>
      <text class="order-more" bindtap="goToOrders">全部订单 ›</text>
    </view>
    <view class="order-stats">
      <view class="stat-item" bindtap="goToOrders" data-status="0">
        <view class="stat-icon pending">💳</view>
        <text class="stat-count">{{orderStats.pending || 0}}</text>
        <text class="stat-label">待支付</text>
      </view>
      <view class="divider-line"></view>
      <view class="stat-item" bindtap="goToOrders" data-status="1">
        <view class="stat-icon paid">📦</view>
        <text class="stat-count">{{orderStats.paid || 0}}</text>
        <text class="stat-label">待发货</text>
      </view>
      <view class="divider-line"></view>
      <view class="stat-item" bindtap="goToOrders" data-status="2">
        <view class="stat-icon shipped">🚚</view>
        <text class="stat-count">{{orderStats.shipped || 0}}</text>
        <text class="stat-label">待收货</text>
      </view>
      <view class="divider-line"></view>
      <view class="stat-item" bindtap="goToOrders" data-status="3">
        <view class="stat-icon completed">✅</view>
        <text class="stat-count">{{orderStats.completed || 0}}</text>
        <text class="stat-label">已完成</text>
      </view>
    </view>
  </view>

  <view wx:if="{{userInfo.role === 1}}" class="menu-section owner-section">
    <view class="section-title">店主管理</view>
    <view class="menu-item" bindtap="goToOwnerOrders">
      <view class="menu-icon-wrapper orders">
        <text class="menu-icon">📦</text>
      </view>
      <view class="menu-content">
        <text class="menu-name">订单管理</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
    <view class="menu-item" bindtap="goToOwnerProducts">
      <view class="menu-icon-wrapper products">
        <text class="menu-icon">🛍️</text>
      </view>
      <view class="menu-content">
        <text class="menu-name">商品管理</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goToOrders">
      <view class="menu-icon-wrapper order">
        <text class="menu-icon">📋</text>
      </view>
      <view class="menu-content">
        <text class="menu-name">我的订单</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
    <view class="menu-item" bindtap="goToAddress">
      <view class="menu-icon-wrapper address">
        <text class="menu-icon">📍</text>
      </view>
      <view class="menu-content">
        <text class="menu-name">收货地址</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="onLogout">
      <view class="menu-icon-wrapper logout">
        <text class="menu-icon">🚪</text>
      </view>
      <view class="menu-content">
        <text class="menu-name">退出登录</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
</view>