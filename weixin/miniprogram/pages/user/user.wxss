.user-page {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 60rpx;
}

.user-header {
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  padding: 80rpx 40rpx 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  position: relative;
  overflow: hidden;
}

.user-header::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.user-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  background: linear-gradient(to bottom, transparent, #f8f9fa);
}

.avatar-wrapper {
  position: relative;
  z-index: 1;
}

.avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(255, 255, 255, 0.8);
  background: #ffffff;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.2);
}

.avatar-placeholder {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder text {
  font-size: 60rpx;
  opacity: 0.6;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  position: relative;
  z-index: 1;
}

.nickname {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.owner-badge {
  background: rgba(255, 255, 255, 0.25);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  position: relative;
  z-index: 1;
}

.menu-section {
  background: #ffffff;
  border-radius: 28rpx;
  margin: -60rpx 24rpx 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 2;
}

.menu-section + .menu-section {
  margin-top: 0;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.owner-section {
  border-left: 6rpx solid #ff6b35;
}

.section-title {
  font-size: 26rpx;
  color: #ff6b35;
  font-weight: 600;
  padding: 20rpx 28rpx 8rpx;
  letter-spacing: 1rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 8rpx;
  background: #ff6b35;
  border-radius: 50%;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: all 0.15s ease;
  gap: 20rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(255, 107, 53, 0.04);
}

.menu-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.menu-item:active .menu-icon-wrapper {
  transform: scale(0.95);
}

.menu-icon {
  font-size: 44rpx;
}

.menu-icon-wrapper.order {
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
}

.menu-icon-wrapper.address {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.menu-icon-wrapper.orders {
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
}

.menu-icon-wrapper.products {
  background: linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%);
}

.menu-icon-wrapper.logout {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.menu-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.menu-name {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.menu-arrow {
  font-size: 32rpx;
  color: #cccccc;
  font-weight: 300;
}

.menu-badge {
  background: #ff4d4f;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  margin-left: 16rpx;
}

.order-section {
  background: #ffffff;
  border-radius: 24rpx;
  margin: 0 24rpx 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.order-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.order-more {
  font-size: 26rpx;
  color: #999999;
}

.order-stats {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.stat-icon.pending {
  background: rgba(255, 107, 53, 0.1);
}

.stat-icon.paid {
  background: rgba(139, 92, 246, 0.1);
}

.stat-icon.shipped {
  background: rgba(59, 130, 246, 0.1);
}

.stat-icon.completed {
  background: rgba(34, 197, 94, 0.1);
}

.stat-label {
  font-size: 24rpx;
  color: #666666;
}

.stat-count {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.divider-line {
  height: 60rpx;
  width: 1rpx;
  background: #f0f0f0;
  margin: 0 16rpx;
}