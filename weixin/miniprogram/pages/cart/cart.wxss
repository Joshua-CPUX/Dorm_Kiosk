.cart-page {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 180rpx;
}

.cart-list {
  padding: 24rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background: #ffffff;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  gap: 24rpx;
  transition: all 0.2s ease;
}

.cart-item:active {
  transform: scale(0.99);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.item-select {
  flex-shrink: 0;
  padding: 8rpx;
}

.checkbox-wrapper {
  position: relative;
  width: 52rpx;
  height: 52rpx;
}

.checkbox {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 3rpx solid #dddddd;
  background: #ffffff;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.checkbox.checked {
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.4);
}

.checkbox.checked::after {
  content: '';
  position: absolute;
  left: 16rpx;
  top: 8rpx;
  width: 14rpx;
  height: 28rpx;
  border: 4rpx solid #ffffff;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}

.item-image-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.item-image {
  width: 100%;
  height: 100%;
  display: block;
}

.item-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f0f0f0 0%, #e8e8e8 100%);
}

.item-image-placeholder text {
  font-size: 24rpx;
  color: #cccccc;
}

.item-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item-name {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

.item-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff6b35;
}

.quantity-control {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 48rpx;
  overflow: hidden;
  padding: 4rpx;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #333333;
  font-weight: 500;
  transition: all 0.2s ease;
  border-radius: 50%;
}

.qty-btn:active {
  background: rgba(255, 107, 53, 0.1);
  color: #ff6b35;
}

.qty-btn.disabled {
  color: #cccccc;
}

.qty-btn.disabled:active {
  background: transparent;
  color: #cccccc;
}

.qty-value {
  min-width: 72rpx;
  text-align: center;
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.item-delete {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  background: rgba(255, 77, 79, 0.08);
  border-radius: 50%;
  transition: all 0.2s ease;
}

.item-delete:active {
  background: rgba(255, 77, 79, 0.15);
  transform: scale(0.9);
}

.item-delete-icon {
  font-size: 28rpx;
  color: #ff4d4f;
}

.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.empty-cart-icon {
  font-size: 160rpx;
  margin-bottom: 40rpx;
  opacity: 0.4;
}

.empty-cart-text {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 48rpx;
}

.go-shopping {
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  color: #ffffff;
  border-radius: 56rpx;
  padding: 28rpx 80rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  gap: 24rpx;
}

.select-all {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.select-all text {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.total-info {
  flex: 1;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  justify-content: flex-end;
}

.total-label {
  font-size: 28rpx;
  color: #666666;
}

.total-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #ff6b35;
}

.checkout-btn {
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  color: #ffffff;
  border-radius: 56rpx;
  padding: 24rpx 64rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 53, 0.4);
  white-space: nowrap;
  transition: all 0.2s ease;
}

.checkout-btn:active {
  transform: scale(0.96);
  box-shadow: 0 3rpx 10rpx rgba(255, 107, 53, 0.5);
}

.checkout-btn.disabled {
  background: #cccccc;
  box-shadow: none;
}

.cart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.cart-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.cart-count {
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
}