/* 购物车页 */
.cart-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* 购物车列表 */
.cart-list {
  padding: 16rpx 0;
}

.cart-item {
  display: flex;
  align-items: center;
  background: #ffffff;
  padding: 24rpx;
  margin-bottom: 2rpx;
  gap: 20rpx;
}

/* 复选框 */
.item-select {
  flex-shrink: 0;
  padding: 8rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #dddddd;
  background: #ffffff;
  transition: all 0.2s;
  position: relative;
}

.checkbox.checked {
  background: #1890ff;
  border-color: #1890ff;
}

.checkbox.checked::after {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 6rpx;
  width: 14rpx;
  height: 22rpx;
  border: 4rpx solid #ffffff;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}

/* 商品图片 */
.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.item-image-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

/* 商品信息 */
.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4d4f;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
  border: 1rpx solid #e8e8e8;
  border-radius: 40rpx;
  overflow: hidden;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333333;
  background: #f5f5f5;
  font-weight: 500;
}

.qty-value {
  width: 64rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  background: #ffffff;
}

/* 删除按钮 */
.item-delete {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #ff4d4f;
  padding: 8rpx 16rpx;
  border: 1rpx solid #ffccc7;
  border-radius: 24rpx;
  background: #fff2f0;
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.empty-cart text {
  font-size: 28rpx;
  color: #bbbbbb;
  margin-bottom: 40rpx;
}

.go-shopping {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: #ffffff;
  border-radius: 48rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
  font-weight: 500;
}

/* 底部结算栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.08);
  gap: 24rpx;
}

.select-all {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.select-all text {
  font-size: 28rpx;
  color: #555555;
}

.total-info {
  flex: 1;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.total-label {
  font-size: 26rpx;
  color: #666666;
}

.total-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.checkout-btn {
  background: linear-gradient(135deg, #ff4d4f, #cf1322);
  color: #ffffff;
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  white-space: nowrap;
}
