page {
  background-color: #f8f9fa;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #1a1a1a;
  box-sizing: border-box;
  line-height: 1.5;
}

view, text {
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.08);
}

.btn-primary {
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  color: #ffffff;
  border-radius: 56rpx;
  padding: 24rpx 56rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 53, 0.4);
  transition: all 0.2s ease;
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 3rpx 10rpx rgba(255, 107, 53, 0.5);
}

.btn-outline {
  border: 2rpx solid #ff6b35;
  color: #ff6b35;
  border-radius: 56rpx;
  padding: 22rpx 56rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  background: #ffffff;
  transition: all 0.2s ease;
}

.btn-outline:active {
  background: #fff8f5;
}

.btn-secondary {
  background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
  color: #ffffff;
  border-radius: 56rpx;
  padding: 24rpx 56rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(108, 117, 141, 0.3);
}

.price-text {
  color: #ff6b35;
  font-weight: 700;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
  color: #999999;
  font-size: 30rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.divider {
  height: 16rpx;
  background: #f8f9fa;
  margin: 0;
}

.glass-effect {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.gradient-primary {
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
}

.gradient-secondary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.gradient-success {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
}

.text-gradient {
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.shadow-sm {
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.shadow-md {
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.shadow-lg {
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.radius-sm {
  border-radius: 12rpx;
}

.radius-md {
  border-radius: 20rpx;
}

.radius-lg {
  border-radius: 32rpx;
}